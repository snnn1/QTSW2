{
  "max_file_size_mb": 50,
  "max_rotated_files": 5,
  "min_log_level": "INFO",
  "enable_diagnostic_logs": false,
  "diagnostic_rate_limits": {
    "tick_heartbeat_minutes": 5,
    "bar_diagnostic_seconds": 300,
    "slot_gate_diagnostic_seconds": 60
  },
  "archive_days": 7,
  "max_queue_size": 50000,
  "max_batch_per_flush": 2000,
  "flush_interval_ms": 500,
  "rotate_daily": false,
  "enable_sensitive_data_filter": true,
  "archive_cleanup_days": 30,
  "event_rate_limits": {
    "BAR_ACCEPTED": 12,
    "BAR_DELIVERY_TO_STREAM": 12,
    "BAR_ROUTING_DIAGNOSTIC": 1,
    "RISK_CHECK_EVALUATED": 60,
    "SLOT_GATE_DIAGNOSTIC": 1,
    "IEA_HEARTBEAT": 12,
    "BE_INTENTS_SCANNED": 60,
    "CRITICAL_NOTIFICATION_SKIPPED": 2
  }
}
